# =========================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.
# =========================================================

# ---------- Postgres ----------
POSTGRES_USER=trackmystuff
POSTGRES_PASSWORD=changeme_in_dev
POSTGRES_DB=trackmystuff

# ---------- Backend ----------
# DATABASE_URL uses the docker-compose service name `db`
DATABASE_URL=postgresql://trackmystuff:changeme_in_dev@db:5432/trackmystuff
BACKEND_PORT=4000
NODE_ENV=development
# Generate a long random string, e.g. `openssl rand -hex 32`
SESSION_SECRET=replace_with_long_random_string
FRONTEND_URL=http://localhost:5173

# ---------- Discord OAuth2 ----------
# Create an app at https://discord.com/developers/applications
# Add the redirect URI below in OAuth2 settings
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4000/auth/callback

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:4000
FRONTEND_PORT=5173
